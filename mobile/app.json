{
  "expo": {
    "name": "BookBox",
    "slug": "bookbox-mobile",
    "scheme": "bookbox",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookbox.mobile"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.bookbox.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#7AF7C4"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "87700c17-c56d-4a16-99df-9319406b77e7"
      }
    }
  }
}
